\name{print.weai_result}
\alias{print.weai_result}
\title{Print a weai_result Object}
\description{
Displays the main empowerment results table.
}
\usage{
\method{print}{weai_result}(x, \dots)
}
\arguments{
  \item{x}{A \code{weai_result} object returned by \code{\link{weai}}.}
  \item{\dots}{Additional arguments (ignored).}
}
\value{Invisibly returns \code{x}.}
\seealso{\code{\link{weai}}, \code{\link{summary.weai_result}}}
